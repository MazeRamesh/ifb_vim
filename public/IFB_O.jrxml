	<queryString>
		<![CDATA[SELECT
     invoices.`id` AS invoices_id,
     invoices.`InternalDocNo` AS invoices_InternalDocNo,
     invoices.`VoucherInvoiceNumber` AS invoices_VoucherInvoiceNumber,
     invoices.`VoucherInvoiceDate` AS invoices_VoucherInvoiceDate,
     invoices.`PONumber` AS invoices_PONumber,
     invoices.`PODate` AS invoices_PODate,
     invoices.`PODateInWord` AS invoices_PODateInWord,
     invoices.`TransporterName` AS invoices_TransporterName,
     invoices.`TransporterNo` AS invoices_TransporterNo,
     invoices.`HMILVendorCode` AS invoices_HMILVendorCode,
     invoices.`GrandTotal` AS invoices_GrandTotal,
     invoices.`GrandTotalInWord` AS invoices_GrandTotalInWord,
     invoices.`GSTIN` AS invoices_GSTIN,
     invoices.`Location` AS invoices_Location,
     invoices.`ShopCode` AS invoices_ShopCode,
     invoices.`GateNo` AS invoices_GateNo,
     invoices.`ContainerType` AS invoices_ContainerType,
     invoices.`NoofContainers` AS invoices_NoofContainers,
     invoices.`StuffQty` AS invoices_StuffQty,
     invoices.`HMILPlant` AS invoices_HMILPlant,
     invoices.`TaxAmount` AS invoices_TaxAmount,
     invoices.`TaxAmountInWord` AS invoices_TaxAmountInWord,
     invoices.`Invoicecount` AS invoices_Invoicecount,
     invoices.`ewaybillno` AS invoices_ewaybillno,
     invoices.`CGST_amt` AS invoices_CGST_amt,
     invoices.`SGST_amt` AS invoices_SGST_amt,
     invoices.`IGST_amt` AS invoices_IGST_amt,
     invoices.`sub_total` AS invoices_sub_total,
     invoices.`created_at` AS invoices_created_at,
     invoices.`SGSTper` AS invoices_SGSTper,
     invoices.`CGSTper` AS invoices_CGSTper,
     invoices.`IGSTper` AS invoices_IGSTper,
     invoices.`pomonth` AS invoices_pomonth,
     invoices.`subtotal` AS invoices_subtotal,
     invoices.`totalqty` AS invoices_totalqty,
     invoices.`totaligst` AS invoices_totaligst,
     invoices.`totalsgst` AS invoices_totalsgst,
     invoices.`totalcgst` AS invoices_totalcgst,
     invoices.`totalinvoicevalue` AS invoices_totalinvoicevalue,
     invoices.`totalinvoicevaluewords` AS invoices_totalinvoicevaluewords,
     invoice_products.`id` AS invoice_products_id,
     invoice_products.`InternalDocNo_id` AS invoice_products_InternalDocNo_id,
     invoice_products.`VoucherInvoiceNumber_id` AS invoice_products_VoucherInvoiceNumber_id,
     invoice_products.`PONumber` AS invoice_products_PONumber,
     invoice_products.`PODate` AS invoice_products_PODate,
     invoice_products.`PODateInWord` AS invoice_products_PODateInWord,
     invoice_products.`ItemNumber` AS invoice_products_ItemNumber,
     invoice_products.`HMILPartDescription` AS invoice_products_HMILPartDescription,
     invoice_products.`HMILPartNo` AS invoice_products_HMILPartNo,
     invoice_products.`ITWPartNo` AS invoice_products_ITWPartNo,
     invoice_products.`HSNCode` AS invoice_products_HSNCode,
     invoice_products.`TarriffNo` AS invoice_products_TarriffNo,
     invoice_products.`ItemServiceDescription` AS invoice_products_ItemServiceDescription,
     invoice_products.`NoOfCases` AS invoice_products_NoOfCases,
     invoice_products.`ItemQuantity` AS invoice_products_ItemQuantity,
     invoice_products.`BaseUOM` AS invoice_products_BaseUOM,
     invoice_products.`ItemUnitRate` AS invoice_products_ItemUnitRate,
     invoice_products.`ItemUnitAmount` AS invoice_products_ItemUnitAmount,
     invoice_products.`SGSTper` AS invoice_products_SGSTper,
     invoice_products.`SGSTamt` AS invoice_products_SGSTamt,
     invoice_products.`CGSTper` AS invoice_products_CGSTper,
     invoice_products.`CGSTamt` AS invoice_products_CGSTamt,
     invoice_products.`IGSTper` AS invoice_products_IGSTper,
     invoice_products.`IGSTamt` AS invoice_products_IGSTamt,
     invoice_products.`MaterialCost` AS invoice_products_MaterialCost,
     invoice_products.`TaxAmount` AS invoice_products_TaxAmount,
     invoice_products.`GrandTotal` AS invoice_products_GrandTotal,
     invoice_products.`NetAmount` AS invoice_products_NetAmount,
     invoice_products.`ConsPartCost` AS invoice_products_ConsPartCost,
     invoice_products.`AssessableValue` AS invoice_products_AssessableValue,
     invoice_products.`ToolCost` AS invoice_products_ToolCost,
     invoice_products.`ConsMatlCost` AS invoice_products_ConsMatlCost,
     invoice_products.`InvoiceID_count` AS invoice_products_InvoiceID_count,
     invoice_products.`TaxAmountInWord` AS invoice_products_TaxAmountInWord,
     invoice_products.`created_at` AS invoice_products_created_at,
     invoice_products.`PONo` AS invoice_products_PONo,
     invoice_products.`Stuff_Qty` AS invoice_products_Stuff_Qty,
     invoice_products.`Cont_Type` AS invoice_products_Cont_Type,
     invoice_products.`No_of_Cont` AS invoice_products_No_of_Cont,
     invoice_products.`ALC` AS invoice_products_ALC,
     invoice_products.`Amort_Cost` AS invoice_products_Amort_Cost,
     invoice_products.`TotalAmort_Cost` AS invoice_products_TotalAmort_Cost,
     invoices.`unittotal` AS invoices_unittotal,
     invoices.`TCS_Percentage` AS invoices_TCS_Percentage,
     invoices.`TCS_Amount` AS invoices_TCS_Amount,
     invoices.`IRN_Number` AS invoices_IRN_Number,
	 invoices.`InvocingPlantAddress` AS invoices_InvocingPlantAddress,
     x.copy,x.sequence
FROM
     `invoices` invoices INNER JOIN `invoice_products` invoice_products ON invoices.`VoucherInvoiceNumber` = invoice_products.`VoucherInvoiceNumber_id`
CROSS JOIN
(
$P!{copy_sql}
) x
WHERE
     invoices.`VoucherInvoiceNumber` = $P{invoicenumber}]]>
	</queryString>
