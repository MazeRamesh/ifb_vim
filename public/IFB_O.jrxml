	<parameter name="copy_sql" class="java.lang.String">
		<defaultValueExpression><![CDATA["Select 'ORIGINAL FOR RECIPIENT' as copy, 1 as sequence UNION SELECT 'DUPLICATE FOR TRANSPORTER' as copy, 2 as sequence UNION SELECT 'TRIPLICATE FOR SUPPLIER' as copy, 3 as sequence UNION SELECT 'EXTRA COPY' as copy, 4 as sequence"]]></defaultValueExpression>
	</parameter>
